{
  "compilerOptions": {
    "target": "es2018",
    "module": "commonjs",
    "rootDir": "./providers",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["providers/**/*", "providers/*.ts"],
  "exclude": ["node_modules", "dist"]
}
